# Managed by Ansible — editable at runtime for tuning
LLAMA_MODEL={{ llm_server_model_dir }}/{{ model.model_filename }}
LLAMA_ALIAS={{ model.model_alias }}
LLAMA_GPU_LAYERS={{ model.gpu_layers | default(llm_server_gpu_layers) }}
LLAMA_SPLIT_MODE={{ model.split_mode | default(llm_server_split_mode) }}
LLAMA_CTX_SIZE={{ model.ctx_size | default(llm_server_ctx_size) }}
LLAMA_THREADS={{ model.threads | default(llm_server_threads) }}
LLAMA_THREADS_BATCH={{ model.threads_batch | default(llm_server_threads_batch) }}
LLAMA_TENSOR_SPLIT={{ model.tensor_split | default(llm_server_tensor_split) }}
LLAMA_CACHE_TYPE_K={{ model.cache_type_k | default(llm_server_cache_type_k) }}
LLAMA_CACHE_TYPE_V={{ model.cache_type_v | default(llm_server_cache_type_v) }}
LLAMA_HOST={{ llm_server_host }}
LLAMA_PORT={{ llm_server_port }}
LLAMA_PARALLEL={{ llm_server_parallel }}
{% if model.mmproj_filename is defined and model.mmproj_filename %}
LLAMA_MMPROJ={{ llm_server_model_dir }}/{{ model.mmproj_filename }}
{% endif %}
{% if model.reasoning_format is defined and model.reasoning_format %}
LLAMA_REASONING_FORMAT={{ model.reasoning_format }}
{% endif %}
{% if model.temp is defined and model.temp is not none %}
LLAMA_TEMP={{ model.temp }}
{% endif %}
{% if model.top_p is defined and model.top_p is not none %}
LLAMA_TOP_P={{ model.top_p }}
{% endif %}
{% if model.top_k is defined and model.top_k is not none %}
LLAMA_TOP_K={{ model.top_k }}
{% endif %}
