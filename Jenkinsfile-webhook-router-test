// Test Router Pipeline for NetBox Webhook Integration
// Story 1.2: 配置 NetBox Webhook 到 Jenkins
// This is a TEST pipeline - does NOT trigger actual deployments

properties([
    pipelineTriggers([
        GenericTrigger(
            // Extract variables from NetBox Webhook Payload
            genericVariables: [
                // Full payload for debugging
                [key: 'webhook_payload', value: '$', expressionType: 'JSONPath'],
                
                // NetBox 4.x Event metadata
                [key: 'netbox_event', value: '$.event', expressionType: 'JSONPath'],
                [key: 'netbox_model', value: '$.model', expressionType: 'JSONPath'],
                [key: 'netbox_username', value: '$.username', expressionType: 'JSONPath'],
                [key: 'netbox_request_id', value: '$.request_id', expressionType: 'JSONPath'],
                
                // NetBox 4.x uses snapshots.postchange instead of data
                [key: 'netbox_object_id', value: '$.snapshots.postchange.id', expressionType: 'JSONPath'],
                [key: 'netbox_object_name', value: '$.snapshots.postchange.name', expressionType: 'JSONPath'],
                [key: 'netbox_object_status', value: '$.snapshots.postchange.status.value', expressionType: 'JSONPath'],
                
                // Custom Fields from Story 1.1
                [key: 'infrastructure_platform', value: '$.snapshots.postchange.custom_fields.infrastructure_platform', expressionType: 'JSONPath'],
                [key: 'automation_level', value: '$.snapshots.postchange.custom_fields.automation_level', expressionType: 'JSONPath'],
                [key: 'proxmox_node', value: '$.snapshots.postchange.custom_fields.proxmox_node', expressionType: 'JSONPath'],
                [key: 'proxmox_vmid', value: '$.snapshots.postchange.custom_fields.proxmox_vmid', expressionType: 'JSONPath'],
                [key: 'ansible_groups', value: '$.snapshots.postchange.custom_fields.ansible_groups', expressionType: 'JSONPath'],
                [key: 'playbook_name', value: '$.snapshots.postchange.custom_fields.playbook_name', expressionType: 'JSONPath']
            ],
            
            // Token authentication (matches NetBox Webhook URL)
            token: 'netbox-webhook',
            
            // Optional: Filter to only trigger on specific events
            // Regexp matches against "$netbox_event $netbox_model"
            regexpFilterText: '$netbox_event $netbox_model',
            regexpFilterExpression: '^(object_created|object_updated) (virtualmachine|device)$',
            
            // Enable debug logging
            printContributedVariables: true,
            printPostContent: true,
            
            // Build cause description
            causeString: 'NetBox Webhook: $netbox_event on $netbox_model "$netbox_object_name" (ID: $netbox_object_id)'
        )
    ])
])

pipeline {
    agent any
    
    options {
        // Keep last 20 builds for webhook history
        buildDiscarder(logRotator(numToKeepStr: '20'))
        // Timeout after 5 minutes (webhook response test should be fast)
        timeout(time: 5, unit: 'MINUTES')
        // Allow concurrent webhook triggers
        // disableConcurrentBuilds()
        ansiColor('xterm')
    }
    
    stages {
        stage('Parse Webhook Payload') {
            steps {
                script {
                    echo "=========================================="
                    echo "      NetBox Webhook Triggered           "
                    echo "=========================================="
                    echo "Event Type     : ${env.netbox_event ?: 'N/A'}"
                    echo "Model          : ${env.netbox_model ?: 'N/A'}"
                    echo "Object ID      : ${env.netbox_object_id ?: 'N/A'}"
                    echo "Object Name    : ${env.netbox_object_name ?: 'N/A'}"
                    echo "Object Status  : ${env.netbox_object_status ?: 'N/A'}"
                    echo "Triggered By   : ${env.netbox_username ?: 'N/A'}"
                    echo "Request ID     : ${env.netbox_request_id ?: 'N/A'}"
                    echo "=========================================="
                    echo ""
                    echo "Custom Fields (Story 1.1):"
                    echo "  infrastructure_platform: ${env.infrastructure_platform ?: 'N/A'}"
                    echo "  automation_level       : ${env.automation_level ?: 'N/A'}"
                    echo "  proxmox_node           : ${env.proxmox_node ?: 'N/A'}"
                    echo "  proxmox_vmid           : ${env.proxmox_vmid ?: 'N/A'}"
                    echo "  ansible_groups         : ${env.ansible_groups ?: 'N/A'}"
                    echo "  playbook_name          : ${env.playbook_name ?: 'N/A'}"
                    echo "=========================================="
                    echo ""
                    
                    // Parse and pretty-print full payload for debugging
                    if (env.webhook_payload) {
                        echo "Full Webhook Payload:"
                        def payload = readJSON text: env.webhook_payload
                        echo groovy.json.JsonOutput.prettyPrint(groovy.json.JsonOutput.toJson(payload))
                    } else {
                        echo "WARNING: webhook_payload is empty"
                    }
                }
            }
        }
        
        stage('Validate Payload') {
            steps {
                script {
                    def errors = []
                    
                    // Check required NetBox metadata
                    if (!env.netbox_event) {
                        errors.add("Missing field: event")
                    }
                    if (!env.netbox_model) {
                        errors.add("Missing field: model")
                    }
                    if (!env.netbox_object_id) {
                        errors.add("Missing field: snapshots.postchange.id")
                    }
                    if (!env.netbox_object_name) {
                        errors.add("Missing field: snapshots.postchange.name")
                    }
                    
                    // Check required Custom Fields from Story 1.1
                    if (!env.infrastructure_platform) {
                        errors.add("Missing custom_fields.infrastructure_platform")
                    }
                    if (!env.automation_level) {
                        errors.add("Missing custom_fields.automation_level")
                    }
                    
                    // Platform-specific validation
                    if (env.infrastructure_platform == 'proxmox') {
                        if (!env.proxmox_node) {
                            errors.add("Missing custom_fields.proxmox_node (required for Proxmox VMs)")
                        }
                    }
                    
                    // Report validation results
                    if (errors) {
                        echo "❌ Payload Validation Failed:"
                        errors.each { echo "   - ${it}" }
                        error "Webhook payload is missing required fields. See errors above."
                    } else {
                        echo "✅ Payload validation passed"
                        echo "   All required fields are present"
                    }
                }
            }
        }
        
        stage('Route Decision') {
            steps {
                script {
                    echo ""
                    echo "=========================================="
                    echo "      Router Decision Logic               "
                    echo "=========================================="
                    
                    def platform = env.infrastructure_platform
                    def automationLevel = env.automation_level
                    def event = env.netbox_event
                    
                    echo "Platform        : ${platform}"
                    echo "Automation Level: ${automationLevel}"
                    echo "Event Type      : ${event}"
                    echo ""
                    
                    // Router logic based on infrastructure_platform
                    switch(platform) {
                        case 'proxmox':
                            echo "🔀 Route Target: Proxmox-Provisioning Pipeline"
                            echo "   Description: Terraform Proxmox VM/LXC provisioning + Ansible deployment"
                            echo "   Next Step  : Would trigger job 'Proxmox-Provisioning'"
                            echo "   Parameters :"
                            echo "     - NETBOX_VM_ID      : ${env.netbox_object_id}"
                            echo "     - AUTOMATION_LEVEL  : ${automationLevel}"
                            echo "     - PROXMOX_NODE      : ${env.proxmox_node ?: 'auto-select'}"
                            echo "     - PROXMOX_VMID      : ${env.proxmox_vmid ?: 'auto-assign'}"
                            
                            // Note: In production Router Pipeline (Story 2.1), this would be:
                            // build job: 'Proxmox-Provisioning', 
                            //       parameters: [
                            //           string(name: 'NETBOX_VM_ID', value: env.netbox_object_id),
                            //           string(name: 'AUTOMATION_LEVEL', value: automationLevel)
                            //       ]
                            break
                            
                        case 'esxi':
                            echo "🔀 Route Target: ESXi-Provisioning Pipeline"
                            echo "   Description: Terraform vSphere VM provisioning + Ansible deployment"
                            echo "   Next Step  : Would trigger job 'ESXi-Provisioning'"
                            echo "   Parameters :"
                            echo "     - NETBOX_VM_ID      : ${env.netbox_object_id}"
                            echo "     - AUTOMATION_LEVEL  : ${automationLevel}"
                            echo ""
                            echo "   ⚠️  Note: ESXi Pipeline not yet implemented (Post-MVP Epic 9)"
                            break
                            
                        case 'physical':
                            echo "🔀 Route Target: Physical-Device-Sync Pipeline"
                            echo "   Description: Skip Terraform, direct Ansible configuration management"
                            echo "   Next Step  : Would trigger job 'Physical-Device-Sync'"
                            echo "   Parameters :"
                            echo "     - NETBOX_DEVICE_ID  : ${env.netbox_object_id}"
                            echo "     - AUTOMATION_LEVEL  : ${automationLevel}"
                            echo ""
                            echo "   ⚠️  Note: Physical Device Pipeline not yet implemented (Epic 8)"
                            break
                            
                        default:
                            error "❌ Unknown infrastructure_platform: '${platform}'. Valid values: proxmox, esxi, physical"
                    }
                    
                    echo "=========================================="
                    echo ""
                    
                    // Automation level advisory (not enforced in test pipeline)
                    if (automationLevel == 'fully_automated') {
                        echo "ℹ️  Automation Level: fully_automated"
                        echo "   → In production, Terraform Apply would run WITHOUT manual approval"
                    } else if (automationLevel == 'requires_approval') {
                        echo "ℹ️  Automation Level: requires_approval"
                        echo "   → In production, Terraform Apply would PAUSE for manual approval"
                    } else if (automationLevel == 'manual_only') {
                        echo "⚠️  Automation Level: manual_only"
                        echo "   → In production, Pipeline would STOP after Terraform Plan"
                        echo "   → Manual execution required via Jenkins UI"
                    }
                }
            }
        }
        
        stage('Test Summary') {
            steps {
                script {
                    echo ""
                    echo "=========================================="
                    echo "      Webhook Router Test Summary        "
                    echo "=========================================="
                    echo "✅ Webhook triggered successfully"
                    echo "✅ Payload parsed and validated"
                    echo "✅ Routing decision completed"
                    echo ""
                    echo "Next Steps:"
                    echo "  1. Review logs above to verify correct field extraction"
                    echo "  2. Confirm infrastructure_platform routing is correct"
                    echo "  3. Proceed to Story 2.1 to build production Router Pipeline"
                    echo ""
                    echo "Story 1.2 Verification:"
                    echo "  - NetBox Webhook → Jenkins trigger: ✅ Working"
                    echo "  - Generic Webhook Trigger plugin  : ✅ Configured"
                    echo "  - Payload parsing (NetBox 4.x)    : ✅ Validated"
                    echo "  - Custom Fields extraction        : ✅ Tested"
                    echo "=========================================="
                }
            }
        }
    }
    
    post {
        success {
            echo "✅ Webhook Router Test completed successfully"
            echo "   Trigger latency: Check build timestamp vs webhook send time"
        }
        failure {
            echo "❌ Webhook Router Test failed"
            echo "   Check errors in 'Validate Payload' or 'Route Decision' stages"
        }
        always {
            // Record build metadata for debugging
            script {
                currentBuild.description = "${env.netbox_event} | ${env.infrastructure_platform} | ${env.netbox_object_name}"
            }
        }
    }
}
